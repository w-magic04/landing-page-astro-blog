---
// ملف: src/pages/index.astro
// تم تنظيف الكود من جميع أنظمة الاشتراك ونقل العناصر للأسفل
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>Winter Magic</title>
        <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;700&family=Inter:wght@400;600&display=swap" rel="stylesheet">
	</head>
	<body>
        <div class="frosted-border"></div>

		<div class="landing-container">
            <header>
                <div class="logo">
                    <span class="winter-text">Winter</span>
                    <span class="magic-text">Magic</span>
                </div>
                <nav>
                    <ul>
                        <li><a href="#" class="active">Discover</a></li>
                        <li><a href="#">Gallery</a></li>
                        <li><a href="#">Contact</a></li>
                    </ul>
                </nav>
            </header>

            <main>
                <div class="top-spacer"></div>

                <div class="bottom-content-area">
                    <h2 class="subtitle">WINTER MAGIC WILL BE HERE SOON.</h2>
                    <p class="description">Take your rewards and wait for us to arrive!</p>
                    
                    <div class="button-wrapper">
                        <a href="https://gift.wintermagic.site" class="get-now-link">GET NOW</a>
                    </div>
                </div>
            </main>
		</div>
	</body>
</html>

<style>
    /* الإعدادات الأساسية */
    :root {
        --gold-bright: #fde2a6;
        --gold-deep: #b88f34;
        --text-white: #f8f9fa;
        --font-serif: 'Cinzel', serif;
        --font-sans: 'Inter', sans-serif;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        /* استخدام الصورة المعدلة */
        background-image: url('/santa.jpg.png'); 
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100vh;
        font-family: var(--font-sans);
        color: var(--text-white);
        overflow: hidden;
        position: relative;
    }

    .frosted-border {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        pointer-events: none;
        border: 15px solid rgba(255, 255, 255, 0.08);
        box-shadow: inset 0 0 40px rgba(255, 255, 255, 0.15);
        z-index: 100;
    }

    .landing-container {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        background: radial-gradient(circle, rgba(0,0,0,0) 50%, rgba(10, 23, 46, 0.3) 100%);
        padding: 2rem 4rem;
    }

    /* الهيدر العلوي */
    header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        z-index: 10;
    }

    .logo {
        display: flex;
        flex-direction: column;
        align-items: center;
        line-height: 0.7;
        opacity: 0.9;
    }

    .logo .winter-text {
        font-family: var(--font-serif);
        font-size: 2rem;
        font-weight: 700;
    }

    .logo .magic-text {
        font-family: var(--font-serif); /* يمكن استخدام خط cursive إذا فضلت */
        font-size: 1.5rem;
        color: var(--gold-bright);
        margin-left: 2rem;
    }

    nav ul {
        display: flex;
        gap: 2.5rem;
        list-style: none;
    }

    nav a {
        color: var(--text-white);
        text-decoration: none;
        font-size: 1rem;
        transition: 0.3s;
        text-shadow: 1px 1px 3px rgba(0,0,0,0.8);
    }

    nav a:hover, nav a.active {
        color: var(--gold-bright);
        border-bottom: 2px solid var(--gold-bright);
    }

    /* توزيع المحتوى ليكون في الأسفل (مكان المستطيل الأحمر) */
    main {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: flex-end; /* دفع العناصر للأسفل */
        align-items: center;
        padding-bottom: 5rem; /* مسافة من أسفل الشاشة لتتطابق مع الصورة */
        text-align: center;
    }

    .top-spacer {
        flex: 1; /* يشغل المساحة العلوية لترك سانتا والشعار يظهرون بوضوح */
    }

    .bottom-content-area {
        z-index: 10;
        width: 100%;
        max-width: 800px;
        /* محاكاة مكان المستطيل الأحمر */
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
    }

    .subtitle {
        font-family: var(--font-serif);
        font-size: 1.8rem;
        font-weight: 500;
        letter-spacing: 1.5px;
        color: var(--gold-bright);
        text-shadow: 2px 3px 5px rgba(0, 0, 0, 1);
        line-height: 1.2;
    }

    .description {
        font-size: 1.1rem;
        color: #e0e0e0;
        margin-bottom: 1.2rem;
        text-shadow: 2px 2px 4px rgba(0,0,0,1);
    }

    /* تنسيق الزر الذهبي GET NOW كرابط مباشر */
    .button-wrapper {
        margin-top: 0.5rem;
    }

    .get-now-link {
        display: inline-block;
        background: linear-gradient(to bottom, #ecd093, #b68d3a);
        color: #fff;
        text-decoration: none;
        padding: 0.8rem 3rem; /* حجم طبيعي وأنيق */
        border-radius: 50px;
        font-weight: 700;
        font-size: 1rem;
        letter-spacing: 1px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.5);
        transition: all 0.3s ease;
        border: 1px solid rgba(255, 255, 255, 0.2);
        text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
    }

    .get-now-link:hover {
        transform: translateY(-3px);
        filter: brightness(1.1);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.6);
    }

    /* التجاوب مع الجوال */
    @media (max-width: 768px) {
        .landing-container { padding: 1.5rem; }
        header { flex-direction: column; gap: 1rem; }
        nav ul { gap: 1.2rem; }
        .subtitle { font-size: 1.3rem; }
        .description { font-size: 0.9rem; }
        main { padding-bottom: 3rem; }
        .get-now-link { padding: 0.7rem 2rem; font-size: 0.9rem; }
    }
</style>
