---
// ملف: src/pages/index.astro
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>Winter Magic</title>
        <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;700&family=Inter:wght@400;500;600&family=Great+Vibes&display=swap" rel="stylesheet">
	</head>
	<body>
        <div class="frosted-border"></div>

		<div class="landing-container">
            <header>
                <div class="logo">
                    <span class="winter">Winter</span>
                    <span class="magic">Magic</span>
                </div>
                <nav>
                    <ul>
                        <li><a href="#" class="active">Discover</a></li>
                        <li><a href="#">Gallery</a></li>
                        <li><a href="#">Contact</a></li>
                    </ul>
                </nav>
            </header>

            <main>
                <div class="content-box">
                    <h1 class="title">WINTER MAGIC</h1>
                    <h2 class="subtitle">WINTER MAGIC WILL BE HERE SOON.</h2>
                    <p class="description">Take your rewards and wait for us to arrive!</p>

                    <div class="action-wrapper">
                        <button class="get-now-btn" id="openPopupBtn" type="button">GET NOW</button>
                    </div>
                </div>

                <div class="bottom-spacer"></div> 
            </main>
		</div>

        <div class="popup-overlay" id="popupOverlay">
            <div class="popup-card">
                <button class="close-btn" id="closePopupBtn">&times;</button>
                
                <h3 class="popup-title">Join The Winter Magic</h3>
                <p class="popup-description">Enter your email to unlock your exclusive rewards and get notified the moment we arrive.</p>
                
               <form class="popup-form" action="https://formsubmit.co/info@wintermagic.site" method="POST">
    <input type="text" name="_honey" style="display:none">
    <input type="hidden" name="_next" value="https://your-website-url.pages.dev">
    
    <input type="email" name="email" placeholder="Enter your email address" required />
    <button type="submit">SUBSCRIBE & ACTIVATE</button>
</form>
            </div>
        </div>

        <script>
            const openBtn = document.getElementById('openPopupBtn');
            const closeBtn = document.getElementById('closePopupBtn');
            const overlay = document.getElementById('popupOverlay');

            // فتح النافذة عند الضغط على الزر الذهبي
            openBtn.addEventListener('click', () => {
                overlay.classList.add('active');
            });

            // إغلاق النافذة عند الضغط على زر X
            closeBtn.addEventListener('click', () => {
                overlay.classList.remove('active');
            });

            // إغلاق النافذة عند الضغط في أي مكان خارج الصندوق المربع
            overlay.addEventListener('click', (e) => {
                if (e.target === overlay) {
                    overlay.classList.remove('active');
                }
            });
        </script>
	</body>
</html>

<style>
    /* الإعدادات العامة للـ CSS */
    :root {
        --gold-light: #e8c37d;
        --gold-dark: #b68d3a;
        --text-white: #f8f9fa;
        --font-serif: 'Cinzel', serif;
        --font-sans: 'Inter', sans-serif;
        --font-cursive: 'Great Vibes', cursive;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background-image: url('/santa.jpg.png'); 
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100vh;
        font-family: var(--font-sans);
        color: var(--text-white);
        overflow-x: hidden;
        position: relative;
    }

    .frosted-border {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        pointer-events: none;
        border: 15px solid rgba(255, 255, 255, 0.08);
        box-shadow: inset 0 0 40px rgba(255, 255, 255, 0.15);
        z-index: 100;
    }

    .landing-container {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        background: radial-gradient(circle, rgba(0,0,0,0) 40%, rgba(10, 23, 46, 0.4) 100%);
        padding: 2rem 4rem;
    }

    header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        padding-top: 0.5rem;
        z-index: 10;
        margin-bottom: 2rem;
    }

    .logo {
        display: flex;
        flex-direction: column;
        align-items: center;
        line-height: 0.7;
    }

    .logo .winter {
        font-family: var(--font-serif);
        font-size: 2.2rem;
        font-weight: 700;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.6);
    }

    .logo .magic {
        font-family: var(--font-cursive);
        font-size: 2.4rem;
        color: var(--gold-light);
        margin-left: 2.5rem;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.6);
    }

    nav ul {
        display: flex;
        gap: 2.5rem;
        list-style: none;
    }

    nav a {
        color: var(--text-white);
        text-decoration: none;
        font-size: 1.05rem;
        font-weight: 500;
        transition: all 0.3s ease;
        text-shadow: 1px 1px 3px rgba(0,0,0,0.8);
    }

    nav a:hover, nav a.active {
        color: var(--gold-light);
        border-bottom: 2px solid var(--gold-light);
        padding-bottom: 4px;
    }

    main {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        text-align: center;
    }

    .content-box {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
        max-width: 800px;
        z-index: 10;
        margin-top: 1rem;
    }

    .title {
        font-family: var(--font-serif);
        font-size: 3.8rem;
        font-weight: 700;
        letter-spacing: 4px;
        background: linear-gradient(to bottom, #ffe8b5, #cfa343);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        filter: drop-shadow(2px 4px 6px rgba(0, 0, 0, 0.9));
        line-height: 1.1;
    }

    .subtitle {
        font-family: var(--font-serif);
        font-size: 2.1rem;
        font-weight: 500;
        letter-spacing: 1px;
        background: linear-gradient(to bottom, #fde2a6, #b88f34);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        filter: drop-shadow(2px 3px 5px rgba(0, 0, 0, 0.9));
        margin-top: 0.4rem;
        margin-bottom: 0.6rem;
    }

    .description {
        font-size: 1.3rem;
        color: #f0f0f0;
        margin-bottom: 1.5rem;
        text-shadow: 2px 2px 5px rgba(0,0,0,1);
    }

    .action-wrapper {
        width: 100%;
        display: flex;
        justify-content: center;
    }

    .get-now-btn {
        background: linear-gradient(to bottom, #ecd093, #b68d3a);
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.4);
        padding: 0.9rem 3.5rem;
        border-radius: 50px;
        font-family: var(--font-sans);
        font-weight: 700;
        font-size: 1.1rem;
        letter-spacing: 1px;
        cursor: pointer;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.5);
        transition: all 0.2s ease;
        text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
    }

    .get-now-btn:hover {
        transform: translateY(-2px);
        filter: brightness(1.1);
        box-shadow: 0 8px 25px rgba(182, 141, 58, 0.4);
    }

    .bottom-spacer {
        flex: 1;
        min-height: 45vh; 
    }

    /* ================= ستايل النافذة المنبثقة (Popup CSS) ================= */
    .popup-overlay {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        background-color: rgba(6, 15, 30, 0.7); /* خلفية داكنة خفيفة */
        backdrop-filter: blur(8px); /* تأثير التغبيش الزجاجي الفاخر */
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 200;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
    }

    /* يظهر البوب أب عند إضافة الكلاس active عبر جافاسكريبت */
    .popup-overlay.active {
        opacity: 1;
        pointer-events: auto;
    }

    .popup-card {
        background: linear-gradient(135deg, rgba(20, 35, 65, 0.9), rgba(10, 20, 40, 0.95));
        border: 2px solid rgba(232, 195, 125, 0.3); /* إطار ذهبي خفيف */
        padding: 3rem 2.5rem;
        border-radius: 24px;
        width: 90%;
        max-width: 480px;
        text-align: center;
        position: relative;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6);
        transform: translateY(-2px);
    }

    .close-btn {
        position: absolute;
        top: 15px; right: 20px;
        background: none;
        border: none;
        color: #fff;
        font-size: 2rem;
        cursor: pointer;
        opacity: 0.6;
        transition: opacity 0.2s;
    }

    .close-btn:hover { opacity: 1; color: var(--gold-light); }

    .popup-title {
        font-family: var(--font-serif);
        font-size: 1.8rem;
        color: var(--gold-light);
        margin-bottom: 1rem;
        letter-spacing: 1px;
    }

    .popup-description {
        font-size: 0.95rem;
        color: #ccd6f6;
        line-height: 1.6;
        margin-bottom: 2rem;
    }

    .popup-form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        width: 100%;
    }

    .popup-form input[type="email"] {
        width: 100%;
        padding: 1rem;
        border-radius: 50px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        background: rgba(255, 255, 255, 0.05);
        color: white;
        font-size: 1rem;
        outline: none;
        text-align: center;
        transition: all 0.3s;
    }

    .popup-form input[type="email"]:focus {
        border-color: var(--gold-light);
        background: rgba(255, 255, 255, 0.1);
    }

    .popup-form button {
        background: linear-gradient(to bottom, #ecd093, #b68d3a);
        color: white;
        border: none;
        padding: 1rem;
        border-radius: 50px;
        font-weight: 700;
        font-size: 1rem;
        cursor: pointer;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
        transition: transform 0.2s;
    }

    .popup-form button:hover {
        transform: translateY(-1px);
        filter: brightness(1.1);
    }

    @media (max-width: 768px) {
        .landing-container { padding: 1.5rem; }
        header { flex-direction: column; gap: 1rem; margin-bottom: 1rem; }
        .logo .magic { margin-left: 1rem; }
        nav ul { gap: 1.2rem; }
        .title { font-size: 2.4rem; letter-spacing: 2px; }
        .subtitle { font-size: 1.3rem; }
        .description { font-size: 1rem; margin-bottom: 1.2rem; }
        .get-now-btn { font-size: 0.95rem; padding: 0.8rem 2.5rem; }
        .bottom-spacer { min-height: 35vh; }
        .popup-card { padding: 2rem 1.5rem; }
    }
</style>
