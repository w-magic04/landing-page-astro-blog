---
// هنا يمكنك كتابة أي كود جافاسكريبت للتحكم بالمنطق الخاص بالصفحة (Server-side)
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>Winter Magic - Coming Soon</title>
        <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@600;700&family=Inter:wght@400;500&family=Great+Vibes&display=swap" rel="stylesheet">
	</head>
	<body>
        <div class="frosted-border"></div>

		<div class="landing-container">
            <header>
                <div class="logo">
                    <span class="winter">Winter</span>
                    <span class="magic">Magic</span>
                </div>
                <nav>
                    <ul>
                        <li><a href="#" class="active">Discover</a></li>
                        <li><a href="#">Gallery</a></li>
                        <li><a href="#">Contact</a></li>
                    </ul>
                </nav>
            </header>

            <main>
                <div class="spacer"></div> 

                <div class="content-box">
                    <h1 class="title">WINTER MAGIC</h1>
                    <h2 class="subtitle">WINTER MAGIC WILL BE HERE SOON.</h2>
                    <p class="description">Take your rewards and wait for us to arrive!</p>

                    <form class="subscribe-form">
                        <div class="input-wrapper">
                            <div class="snow-effect"></div>
                            <input type="email" placeholder="" required />
                        </div>
                        <button type="submit">SUBSCRIBE WITH EMAIL - DON'T FORGET TO ACTIVATE YOUR EMAIL</button>
                    </form>
                </div>
            </main>
		</div>
	</body>
</html>

<style>
    /* الإعدادات العامة */
    :root {
        --gold: #d4af37;
        --gold-light: #e8c37d;
        --text-white: #f8f9fa;
        --font-serif: 'Cinzel', serif;
        --font-sans: 'Inter', sans-serif;
        --font-cursive: 'Great Vibes', cursive;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        /* ضع مسار صورتك هنا */
        background-image: url('/background.jpg.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100vh;
        font-family: var(--font-sans);
        color: var(--text-white);
        overflow-x: hidden;
        position: relative;
    }

    /* الإطار الجليدي المحيط بالصفحة */
    .frosted-border {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        pointer-events: none;
        border: 15px solid rgba(255, 255, 255, 0.1);
        box-shadow: inset 0 0 50px rgba(255, 255, 255, 0.2);
        z-index: 100;
    }

    .landing-container {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        background: radial-gradient(circle, rgba(0,0,0,0) 40%, rgba(12, 28, 56, 0.7) 100%); /* تعتيم الحواف لإبراز النص */
        padding: 2rem 4rem;
    }

    /* Header & Nav */
    header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        padding-top: 1rem;
    }

    .logo {
        display: flex;
        flex-direction: column;
        align-items: center;
        line-height: 0.8;
    }

    .logo .winter {
        font-family: var(--font-serif);
        font-size: 2rem;
        font-weight: 700;
    }

    .logo .magic {
        font-family: var(--font-cursive);
        font-size: 2.2rem;
        color: var(--gold-light);
        margin-left: 2rem;
    }

    nav ul {
        display: flex;
        gap: 2rem;
        list-style: none;
    }

    nav a {
        color: var(--text-white);
        text-decoration: none;
        font-size: 1rem;
        transition: color 0.3s ease;
    }

    nav a:hover, nav a.active {
        color: var(--gold-light);
        border-bottom: 1px solid var(--gold-light);
        padding-bottom: 2px;
    }

    /* Main Content */
    main {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-end; /* لتركيز المحتوى في الأسفل كما في الصورة */
        padding-bottom: 4rem;
        text-align: center;
    }

    .spacer {
        flex: 1; /* هذه المساحة ستترك مكان لسانتا كلوز ليكون مرئياً من صورة الخلفية */
        min-height: 40vh;
    }

    .content-box {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.8); /* ظل قوي للنصوص لجعلها مقروءة فوق الخلفية */
    }

    .title {
        font-family: var(--font-serif);
        font-size: 3.5rem;
        color: var(--gold-light);
        letter-spacing: 2px;
    }

    .subtitle {
        font-family: var(--font-serif);
        font-size: 2.2rem;
        color: var(--gold-light);
        letter-spacing: 1px;
    }

    .description {
        font-size: 1.2rem;
        margin-bottom: 2rem;
        margin-top: 0.5rem;
        text-shadow: 1px 1px 3px rgba(0,0,0,0.9);
    }

    /* Form Styles */
    .subscribe-form {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        width: 100%;
        max-width: 600px;
    }

    .input-wrapper {
        position: relative;
        width: 100%;
    }

    /* محاولة لمحاكاة الثلج المتراكم على حقل الإدخال */
    .snow-effect {
        position: absolute;
        top: -10px;
        left: 5%;
        width: 90%;
        height: 20px;
        background: #fff;
        border-radius: 50%;
        filter: blur(2px);
        opacity: 0.8;
        pointer-events: none;
    }

    input[type="email"] {
        width: 100%;
        padding: 1rem 2rem;
        border-radius: 50px;
        border: 2px solid rgba(255, 255, 255, 0.6);
        background-color: rgba(255, 255, 255, 0.9);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
        font-size: 1.1rem;
        outline: none;
        transition: all 0.3s;
    }

    input[type="email"]:focus {
        border-color: var(--gold-light);
        background-color: #fff;
    }

    button {
        background: linear-gradient(to bottom, #e4c580, #c29b4b);
        color: white;
        border: 2px solid rgba(255, 255, 255, 0.3);
        padding: 1rem 2rem;
        border-radius: 50px;
        font-family: var(--font-sans);
        font-weight: 500;
        font-size: 0.9rem;
        letter-spacing: 0.5px;
        cursor: pointer;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.4);
        transition: transform 0.2s, filter 0.2s;
        width: 100%;
    }

    button:hover {
        transform: translateY(-2px);
        filter: brightness(1.1);
    }

    /* Media Queries للتجاوب مع الشاشات الصغيرة */
    @media (max-width: 768px) {
        .landing-container {
            padding: 1rem;
        }
        header {
            flex-direction: column;
            gap: 1rem;
        }
        .title { font-size: 2.5rem; }
        .subtitle { font-size: 1.5rem; }
        nav ul { gap: 1rem; }
    }
</style>
